# ============================================================
# BIST30 Sinyal Sistemi — Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# ============================================================

# Gmail Gönderen Hesabı
GMAIL_USER=your_gmail@gmail.com

# Gmail Uygulama Şifresi (2FA etkin olmalı)
# Oluşturma: Google Hesabı → Güvenlik → Uygulama Şifreleri
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Raporun gönderileceği e-posta adresi (birden fazla: virgülle ayır)
MAIL_TO=recipient@example.com

# Anthropic API Anahtarı (AI sentiment analizi için)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...
